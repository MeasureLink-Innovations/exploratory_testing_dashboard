PORT=3000
DATABASE_URL=postgres://user:password@localhost:5432/exploratory_testing
JWT_SECRET=replace-with-a-local-secret

# Proxy/TLS awareness
TRUST_PROXY=false

# HSTS (normally enabled at edge proxy in production)
HSTS_ENABLED=false
HSTS_MAX_AGE=300
HSTS_INCLUDE_SUBDOMAINS=false
HSTS_PRELOAD=false
